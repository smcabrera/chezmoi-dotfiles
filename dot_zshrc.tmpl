# -----------------------
# General Config
# -----------------------

setopt NO_BEEP
unsetopt nomatch

# -----------------------
# Zinit
# -----------------------

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# -----------------------
# Starship
# -----------------------

(( $+commands[starship] )) && eval "$(starship init zsh)"

# -----------------------
# Vi Mode Keybinding
# -----------------------

zinit light jeffreytse/zsh-vi-mode
ZVM_VI_INSERT_ESCAPE_BINDKEY='jk'

# -----------------------
# History
# -----------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

# -----------------------
# Environment Variables
# -----------------------
[[ -f "$HOME/.exports" ]] && source "$HOME/.exports"
export GPG_TTY=$(tty)
# export OVERCOMMIT_DISABLE=1

# -----------------------
# Aliases
# -----------------------
[ -e "$HOME/.zsh/aliases.zsh" ] && source "$HOME/.zsh/aliases.zsh"

# -----------------------
# Path Setup
# -----------------------

# This goes last because install tools always append these
export PATH="$HOME/.bin:$HOME/bin:$HOME/.cargo/bin:$HOME/go/bin:$HOME/Dropbox/bin:$HOME/.rbenv/bin:$PATH"
{{ if eq .chezmoi.os "darwin" -}}
export PATH="/opt/homebrew/opt/libpq/bin:/opt/homebrew/opt/openjdk/bin:/opt/homebrew/bin:$PATH"
{{ end -}}
export PATH="/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"
export PATH=/Users/stephen/.opencode/bin:$PATH

# -----------------------
# Tool Setup
# -----------------------
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

{{ if eq .chezmoi.os "darwin" -}}
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}
(( $+commands[rbenv] )) && eval "$(rbenv init - zsh)"
(( $+commands[mcfly] )) && eval "$(mcfly init zsh)"

export PATH="$HOME/.local/bin:$PATH"
(( $+commands[tree-me] )) && source <(tree-me shellenv)

wt() {
  if [[ "$1" == "ls" ]]; then
    worktree ls
  else
    local dir
    dir=$(worktree "$@") && [[ -d "$dir" ]] && cd "$dir"
  fi
}

# bun completions
[ -s "/Users/stephen/.bun/_bun" ] && source "/Users/stephen/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Agent shell integration (loaded last to avoid blocking prompt)
[[ -x "$HOME/.local/bin/agent" ]] && eval "$(~/.local/bin/agent shell-integration zsh)"
