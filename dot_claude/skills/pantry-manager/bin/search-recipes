#!/usr/bin/env ruby
require_relative '../lib/spoonacular_client'

query = ARGV.join(' ')
abort "Usage: search-recipes <ingredient1> [ingredient2] ..." if query.empty?

ingredients = query.split(/[,\s]+/).map(&:strip).reject(&:empty?)

results = PantryManager::SpoonacularClient.search_by_ingredients(ingredients)

if results.empty?
  abort "No recipes found for: #{ingredients.join(', ')}"
end

results.each do |r|
  puts "#{r[:id]}\t#{r[:title]}\t(uses #{r[:used_ingredient_count]} of yours, needs #{r[:missed_ingredient_count]} more)"
end
