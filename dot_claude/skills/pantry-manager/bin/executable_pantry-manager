#!/usr/bin/env ruby

# Get the absolute path to the skill directory
SKILL_DIR = File.expand_path('..', __dir__)

# Add lib directory to load path
$LOAD_PATH.unshift(File.join(SKILL_DIR, 'lib'))

# Require necessary files
require 'database'
require 'models'
require 'cli'

module PantryManager
  class CommandHandler
    def self.run(args)
      # Initialize database connection
      Database.connection

      if args.empty?
        show_usage
        exit 1
      end

      command = args[0]
      command_args = args[1..]

      case command
      when 'add'
        handle_add(command_args)
      when 'list'
        handle_list(command_args)
      when 'remove'
        handle_remove(command_args)
      when 'recipes'
        handle_recipes(command_args)
      when 'recipe'
        handle_recipe(command_args)
      when 'import'
        handle_import(command_args)
      when 'search'
        handle_search(command_args)
      when 'plan'
        handle_plan(command_args)
      when 'favorite'
        handle_favorite(command_args)
      when 'shop'
        handle_shop(command_args)
      when 'save-spoonacular'
        handle_save_spoonacular(command_args)
      when 'help', '--help', '-h'
        show_usage
      else
        puts "Error: Unknown command '#{command}'"
        puts
        show_usage
        exit 1
      end
    rescue => e
      puts "Error: #{e.message}"
      puts e.backtrace if ENV['DEBUG']
      exit 1
    end

    private

    def self.handle_add(args)
      # Natural language mode: single argument (the full phrase)
      if args.length == 1
        handle_natural_language_add(args[0])
      # Structured mode: at least 3 arguments (ingredient, quantity, unit)
      elsif args.length >= 3
        ingredient_name = args[0]
        quantity = args[1]
        unit = args[2]
        notes = args[3]

        PantryItem.add_or_update(ingredient_name, quantity, unit, notes)
        puts "Added #{quantity} #{unit} #{ingredient_name} to pantry."
      else
        puts "Usage:"
        puts "  Natural language: pantry-manager add \"four roma tomatoes and a bag of kale\""
        puts "  Structured: pantry-manager add <ingredient> <quantity> <unit> [notes]"
        puts "Example: pantry-manager add \"red onion\" 2 whole"
        exit 1
      end
    end

    def self.handle_natural_language_add(text)
      require 'natural_language_parser'

      puts "Parsing: #{text}"
      puts

      begin
        items = NaturalLanguageParser.parse(text)

        if items.empty?
          puts "No items found in input."
          exit 1
        end

        # Show parsed items
        puts "Parsed items:"
        items.each_with_index do |item, idx|
          puts "  #{idx + 1}. #{item[:quantity]}x #{item[:name]} (#{item[:unit]})"
        end
        puts

        # Confirm
        print "Add these items to pantry? [y/n/e(dit)]: "
        response = $stdin.gets.chomp.downcase

        case response
        when 'y', 'yes'
          add_items(items)
        when 'e', 'edit'
          edited_items = edit_items(items)
          if edited_items && !edited_items.empty?
            puts
            puts "Edited items:"
            edited_items.each_with_index do |item, idx|
              puts "  #{idx + 1}. #{item[:quantity]}x #{item[:name]} (#{item[:unit]})"
            end
            puts

            print "Add these items to pantry? [y/n]: "
            confirm = $stdin.gets.chomp.downcase
            if confirm == 'y' || confirm == 'yes'
              add_items(edited_items)
            else
              puts "Cancelled."
            end
          else
            puts "Cancelled."
          end
        else
          puts "Cancelled."
        end

      rescue NaturalLanguageParser::ParseError => e
        puts "Parse error: #{e.message}"
        exit 1
      rescue NaturalLanguageParser::APIError => e
        puts "API error: #{e.message}"
        exit 1
      end
    end

    def self.add_items(items)
      items.each do |item|
        PantryItem.add_or_update(item[:name], item[:quantity], item[:unit])
        puts "Added #{item[:quantity]} #{item[:unit]} #{item[:name]} to pantry."
      end
    end

    def self.edit_items(items)
      edited_items = []

      items.each_with_index do |item, idx|
        puts "Item #{idx + 1}: #{item[:quantity]}x #{item[:name]} (#{item[:unit]})"

        print "  Name [#{item[:name]}]: "
        name = $stdin.gets.chomp
        name = item[:name] if name.empty?

        print "  Quantity [#{item[:quantity]}]: "
        quantity = $stdin.gets.chomp
        quantity = item[:quantity] if quantity.empty?

        print "  Unit [#{item[:unit]}]: "
        unit = $stdin.gets.chomp
        unit = item[:unit] if unit.empty?

        print "  Include this item? [y/n]: "
        include = $stdin.gets.chomp.downcase

        if include == 'y' || include == 'yes' || include.empty?
          edited_items << { name: name, quantity: quantity, unit: unit }
        end
        puts
      end

      edited_items
    end

    def self.handle_list(args)
      items = PantryItem.all
      puts CLI.format_pantry_list(items)
    end

    def self.handle_remove(args)
      if args.empty?
        puts "Usage: pantry-manager remove <ingredient>"
        puts "Example: pantry-manager remove \"red onion\""
        exit 1
      end

      ingredient_name = args[0]
      if PantryItem.remove_by_name(ingredient_name)
        puts "Removed #{ingredient_name} from pantry."
      else
        puts "#{ingredient_name} not found in pantry."
      end
    end

    def self.handle_recipes(args)
      recipes = Recipe.all
      puts CLI.format_recipe_list(recipes)
    end

    def self.handle_recipe(args)
      if args.empty?
        puts "Usage: pantry-manager recipe <id>"
        puts "Example: pantry-manager recipe 1"
        exit 1
      end

      recipe_id = args[0]
      recipe = Recipe.find(recipe_id)
      if recipe
        puts CLI.format_recipe_details(recipe)
      else
        puts "Recipe not found."
      end
    end

    def self.handle_import(args)
      if args.empty?
        puts "Usage: pantry-manager import <url>"
        puts "Example: pantry-manager import https://cooking.nytimes.com/recipes/..."
        exit 1
      end

      require 'recipe_importer'

      url = args[0]
      puts "Importing recipe from #{url}..."
      puts "(2-second rate limit for respectful access)"
      puts "⚠️  Personal use only - do not distribute recipe data"
      puts

      result = RecipeImporter.import(url)

      if result[:success]
        puts "✅ Successfully imported: #{result[:title]}"
        puts "   Recipe ID: #{result[:recipe_id]}"
        puts "   Ingredients: #{result[:ingredient_count]}"
        puts "   Parser: #{result[:parser]}" if result[:parser]
      else
        puts "❌ Import failed: #{result[:error]}"
        exit 1
      end
    end

    def self.handle_search(args)
      if args.empty?
        puts "Usage: pantry-manager search <query>"
        puts "Example: pantry-manager search chicken"
        exit 1
      end

      require 'search_orchestrator'

      query = args.join(' ')
      puts "Searching for: #{query}"
      puts

      results = PantryManager::SearchOrchestrator.search(query: query, limit: 10)

      if results.empty?
        puts "No recipes found matching '#{query}'"
        return
      end

      puts "Found #{results.length} recipe(s):"
      puts
      results.each do |result|
        if result.is_a?(Hash) && result[:source] == 'local'
          puts "ID: #{result[:id]} | Title: #{result[:title]}"
        elsif result.is_a?(Hash)
          puts "Title: #{result[:title]}"
          puts "  -> Spoonacular ID: #{result[:id]} (save with: pantry-manager save-spoonacular #{result[:id]})"
        else
          puts "ID: #{result.id} | Title: #{result.title}"
          puts "URL: #{result.source_url}"
        end
        puts
      end
    end

    def self.handle_save_spoonacular(args)
      if args.empty?
        puts "Usage: pantry-manager save-spoonacular <spoonacular_id>"
        puts "Example: pantry-manager save-spoonacular 654476"
        exit 1
      end

      require 'recipe_importer'

      spoonacular_id = args[0].to_i
      puts "Fetching recipe #{spoonacular_id} from Spoonacular..."

      result = PantryManager::RecipeImporter.from_spoonacular(spoonacular_id)

      if result[:success]
        puts "✅ Saved: #{result[:title]}"
        puts "   Recipe ID: #{result[:recipe_id]}"
        puts "   Ingredients: #{result[:ingredient_count]}"
      else
        puts "❌ Failed: #{result[:error]}"
        exit 1
      end
    end

    def self.handle_plan(args)
      if args.empty?
        puts "Usage: pantry-manager plan <N>"
        puts "Example: pantry-manager plan 5"
        puts
        puts "This generates a meal plan for N meals that optimizes ingredient reuse."
        exit 1
      end

      require 'meal_planner'

      num_meals = args[0].to_i
      if num_meals <= 0
        puts "Error: Number of meals must be a positive integer"
        exit 1
      end

      puts "Generating meal plan for #{num_meals} meals..."
      puts

      result = MealPlanner.generate_plan(num_meals: num_meals)

      if result[:error]
        puts "Error: #{result[:error]}"
        exit 1
      end

      # Output the prompt for Claude to process
      puts "**Meal Planning Data:**"
      puts
      puts "Pantry: #{result[:pantry].join(', ')}" if result[:pantry].any?
      puts "Candidates: #{result[:candidates].length} recipes"
      puts
      puts "To complete the meal plan, please provide this data to Claude:"
      puts
      puts result[:prompt]
    end

    def self.handle_favorite(args)
      if args.empty?
        puts "Usage: pantry-manager favorite <recipe_id> [rating] [notes]"
        puts "Example: pantry-manager favorite 1 5 \"Amazing dish!\""
        exit 1
      end

      recipe_id = args[0].to_i
      rating = args[1] ? args[1].to_i : nil
      notes = args[2]

      # Validate rating if provided
      if rating && (rating < 1 || rating > 5)
        puts "Error: Rating must be between 1 and 5"
        exit 1
      end

      db = Database.connection

      # Check if recipe exists
      recipe = Recipe.find(recipe_id)
      unless recipe
        puts "Error: Recipe #{recipe_id} not found"
        exit 1
      end

      # Check if already favorited
      existing = db.execute("SELECT * FROM favorites WHERE recipe_id = ?", [recipe_id]).first

      if existing
        # Update existing favorite
        db.execute(
          "UPDATE favorites SET rating = ?, notes = ? WHERE recipe_id = ?",
          [rating, notes, recipe_id]
        )
        puts "Updated favorite: #{recipe.title}"
      else
        # Insert new favorite
        db.execute(
          "INSERT INTO favorites (recipe_id, rating, notes) VALUES (?, ?, ?)",
          [recipe_id, rating, notes]
        )
        puts "Added to favorites: #{recipe.title}"
      end

      if rating
        puts "Rating: #{rating}/5"
      end
      if notes
        puts "Notes: #{notes}"
      end
    end

    def self.handle_shop(args)
      subcommand = args[0]

      case subcommand
      when 'list'
        items = ShoppingList.list
        puts CLI.format_shopping_list(items)
      when 'add'
        if args.length < 4
          puts "Usage: pantry-manager shop add <ingredient> <quantity> <unit> [notes]"
          puts "Example: pantry-manager shop add lemon 2 whole"
          exit 1
        end
        ingredient, quantity, unit = args[1], args[2], args[3]
        notes = args[4]
        ShoppingList.add(ingredient, quantity, unit, notes: notes)
        puts "Added #{quantity} #{unit} #{ingredient} to shopping list."
      when 'remove'
        if args.length < 2
          puts "Usage: pantry-manager shop remove <ingredient>"
          exit 1
        end
        ingredient = args[1]
        if ShoppingList.remove(ingredient)
          puts "Removed #{ingredient} from shopping list."
        else
          puts "#{ingredient} not found on shopping list."
        end
      when 'buy'
        if args.length < 2
          puts "Usage: pantry-manager shop buy <ingredient> [quantity] [unit]"
          puts "Example: pantry-manager shop buy tahini"
          exit 1
        end
        ingredient = args[1]
        quantity = args[2]
        unit = args[3]
        if ShoppingList.buy(ingredient, quantity: quantity, unit: unit)
          puts "Moved #{ingredient} to pantry."
        else
          puts "#{ingredient} not found on shopping list."
        end
      when 'need'
        if args.length < 2
          puts "Usage: pantry-manager shop need <ingredient>"
          puts "Example: pantry-manager shop need \"olive oil\""
          exit 1
        end
        ingredient = args[1]
        if ShoppingList.need(ingredient)
          puts "Moved #{ingredient} to shopping list."
        else
          puts "#{ingredient} not found in pantry."
        end
      when 'missing'
        if args.length < 2
          puts "Usage: pantry-manager shop missing <recipe_id>"
          puts "Example: pantry-manager shop missing 1"
          exit 1
        end
        recipe_id = args[1].to_i
        added = ShoppingList.add_missing_for_recipe(recipe_id)
        if added.empty?
          puts "You already have all ingredients for this recipe!"
        else
          puts "Added #{added.length} missing ingredient(s) to shopping list:"
          added.each { |item| puts "  - #{item.quantity} #{item.unit} #{item.ingredient_name}" }
        end
      else
        puts "Usage: pantry-manager shop <subcommand>"
        puts
        puts "Subcommands:"
        puts "  list                              Show shopping list"
        puts "  add <ingredient> <qty> <unit>     Add item to shopping list"
        puts "  remove <ingredient>               Remove item from shopping list"
        puts "  buy <ingredient> [qty] [unit]     Move item from shopping list to pantry"
        puts "  need <ingredient>                 Move item from pantry to shopping list"
        puts "  missing <recipe_id>               Add missing recipe ingredients to shopping list"
        exit 1
      end
    end

    def self.show_usage
      puts <<~USAGE
        Pantry Manager - Manage your pantry and plan meals

        Usage: pantry-manager <command> [arguments]

        Commands:
          add "<natural language>" OR add <ingredient> <quantity> <unit> [notes]
              Add or update ingredient(s) in pantry
              Natural language (requires ANTHROPIC_API_KEY):
                pantry-manager add "four roma tomatoes and a bag of kale"
              Structured format:
                pantry-manager add "red onion" 2 whole

          list
              Show all items currently in pantry

          remove <ingredient>
              Remove ingredient from pantry
              Example: pantry-manager remove "red onion"

          recipes
              List all imported recipes

          recipe <id>
              Show details for a specific recipe
              Example: pantry-manager recipe 1

          import <url>
              Import recipe from URL (NYT Cooking, Schema.org sites)
              Example: pantry-manager import https://cooking.nytimes.com/recipes/...
              Note: Personal use only, respects rate limits

          search <query>
              Search recipes (local first, then Spoonacular)
              Example: pantry-manager search chicken

          save-spoonacular <id>
              Save a Spoonacular recipe to your local collection
              Example: pantry-manager save-spoonacular 654476

          plan <N>
              Generate meal plan for N meals optimizing ingredient reuse
              Example: pantry-manager plan 5

          favorite <recipe_id> [rating] [notes]
              Mark recipe as favorite with optional rating (1-5) and notes
              Example: pantry-manager favorite 1 5 "Best pasta ever!"

          shop <subcommand>
              Manage your shopping list
              shop list                              Show shopping list
              shop add <ingredient> <qty> <unit>     Add item to shopping list
              shop remove <ingredient>               Remove item from shopping list
              shop buy <ingredient> [qty] [unit]     Move item to pantry (you bought it)
              shop need <ingredient>                 Move item from pantry to shopping list
              shop missing <recipe_id>               Add missing recipe ingredients to list

          help
              Show this help message

        Database Location:
          ~/.local/share/pantry-manager/pantry.db

        Environment Variables:
          ANTHROPIC_API_KEY - Required for natural language parsing (optional)

        For more information, see SKILL.md
      USAGE
    end
  end
end

# Run the command handler
PantryManager::CommandHandler.run(ARGV)
