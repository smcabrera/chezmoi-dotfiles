#!/usr/bin/env ruby
require 'cgi'
require_relative '../lib/parsers/nyt_parser'
require_relative '../lib/parsers/schema_org_parser'
require_relative '../lib/ingredient_parser'

url = ARGV[0]
abort "Usage: import-recipe <url>" unless url

PARSERS = [
  PantryManager::Parsers::NYTParser,
  PantryManager::Parsers::SchemaOrgParser
]

recipe_data = nil
PARSERS.each do |parser|
  next unless parser.can_parse?(url)
  recipe_data = parser.parse(url)
  break if recipe_data
end

abort "Could not parse recipe from #{url}" unless recipe_data

# Decode HTML entities in text fields
recipe_data[:title] = CGI.unescapeHTML(recipe_data[:title]) if recipe_data[:title]
recipe_data[:ingredients]&.map! { |i| CGI.unescapeHTML(i) }
recipe_data[:steps]&.map! { |s| CGI.unescapeHTML(s) }

# Generate slug from title
slug = recipe_data[:title].downcase.gsub(/[^a-z0-9]+/, '-').gsub(/^-|-$/, '')
output_dir = File.expand_path('~/Dropbox/GoatBot/cooking/recipes')
output_path = File.join(output_dir, "#{slug}.md")

if File.exist?(output_path)
  abort "Recipe already exists: #{output_path}"
end

# Normalize ingredient names for frontmatter (searchable)
normalized_ingredients = recipe_data[:ingredients].map do |ing_text|
  parsed = PantryManager::IngredientParser.parse(ing_text)
  parsed[:name]
end.reject(&:empty?).uniq

# Build markdown
today = Time.now.strftime('%Y-%m-%d')
fm_ingredients = normalized_ingredients.map { |i| "  - #{i}" }.join("\n")
body_ingredients = recipe_data[:ingredients].map { |i| "- #{i}" }.join("\n")
body_steps = recipe_data[:steps].each_with_index.map { |s, i| "#{i + 1}. #{s}" }.join("\n")

markdown = <<~MD
  ---
  source: #{url}
  yield: #{recipe_data[:yield]}
  time: #{recipe_data[:total_time]}
  imported: #{today}
  ingredients:
  #{fm_ingredients}
  ---

  # #{recipe_data[:title]}

  ## Ingredients

  #{body_ingredients}

  ## Instructions

  #{body_steps}
MD

File.write(output_path, markdown.gsub(/^  /, ''))
puts "Imported: #{recipe_data[:title]}"
puts "File: #{output_path}"
puts "Ingredients: #{recipe_data[:ingredients].length}"
